<div class="auth-page">
  <div class="auth-container">
    <div class="auth-header">
      <h1>Create an account</h1>
      <p>Start amplifying your campaigns</p>
    </div>

    <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
      <div class="alert alert-error">
        <% errors.forEach(error => { %>
          <p><%= error.msg %></p>
        <% }); %>
      </div>
    <% } %>

    <form action="/admin/register" method="POST" class="auth-form">
      <div class="form-group">
        <label for="name" class="form-label">Name</label>
        <input
          type="text"
          id="name"
          name="name"
          class="form-input"
          value="<%= typeof values !== 'undefined' && values.name ? values.name : '' %>"
          required
          autofocus
        >
      </div>

      <div class="form-group">
        <label for="email" class="form-label">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          class="form-input"
          value="<%= typeof values !== 'undefined' && values.email ? values.email : '' %>"
          required
        >
      </div>

      <div class="form-group">
        <label for="password" class="form-label">Password</label>
        <input
          type="password"
          id="password"
          name="password"
          class="form-input"
          minlength="8"
          required
        >
        <small class="text-gray text-sm">Must be at least 8 characters</small>
      </div>

      <button type="submit" class="btn btn-primary btn-block btn-lg">
        Create Account
      </button>
    </form>

    <div class="auth-footer">
      <p>Already have an account? <a href="/admin/login">Sign in</a></p>
    </div>
  </div>
</div>

<style>
  .auth-page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 200px);
    padding: var(--spacing-8);
  }

  .auth-container {
    width: 100%;
    max-width: 400px;
  }

  .auth-header {
    text-align: center;
    margin-bottom: var(--spacing-8);
  }

  .auth-header h1 {
    font-size: var(--font-size-3xl);
    color: var(--color-gray-900);
    margin-bottom: var(--spacing-2);
  }

  .auth-header p {
    color: var(--color-gray-500);
  }

  .auth-form {
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-xl);
    padding: var(--spacing-8);
    box-shadow: var(--shadow-lg);
  }

  .auth-footer {
    text-align: center;
    margin-top: var(--spacing-6);
    color: var(--color-gray-500);
  }

  .auth-footer a {
    color: var(--color-secondary);
    font-weight: 500;
  }
</style>
